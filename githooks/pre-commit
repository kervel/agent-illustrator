#!/usr/bin/env bash
# Pre-commit hook: re-render examples and fail if SVGs change
# This catches rendering regressions before they get committed.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"

# Only run if source files changed
if ! git diff --cached --name-only | grep -qE '\.(rs|ail|css)$'; then
    exit 0
fi

echo "pre-commit: re-rendering example SVGs..."

# Build first (needed for rendering)
cargo build --quiet 2>/dev/null || {
    echo "pre-commit: cargo build failed, skipping SVG check"
    exit 0
}

# Per-example stylesheet selection
stylesheet_for() {
    case "$1" in
        mosfet-driver)        echo "$SCRIPT_DIR/stylesheets/kapernikov-schematic.css" ;;
        agentic-loop-story)   echo "$SCRIPT_DIR/stylesheets/agentic-loop-story.css" ;;
        *)                    echo "$SCRIPT_DIR/stylesheets/kapernikov.css" ;;
    esac
}

extra_flags_for() {
    case "$1" in
        agentic-loop-story)   echo "--animate-css" ;;
        *)                    echo "" ;;
    esac
}

# Re-render all examples
CHANGED=0
for ail in "$SCRIPT_DIR"/examples/*.ail; do
    name="$(basename "$ail" .ail)"
    svg="$SCRIPT_DIR/examples/$name.svg"
    css="$(stylesheet_for "$name")"
    flags="$(extra_flags_for "$name")"
    # shellcheck disable=SC2086
    if cargo run --quiet -- "$ail" --stylesheet-css "$css" $flags > "$svg.tmp" 2>/dev/null; then
        if ! diff -q "$svg" "$svg.tmp" > /dev/null 2>&1; then
            echo "  CHANGED: $name.svg"
            mv "$svg.tmp" "$svg"
            git add "$svg"
            CHANGED=1
        else
            rm -f "$svg.tmp"
        fi
    else
        echo "  FAIL: $name.ail (render error)"
        rm -f "$svg.tmp"
        exit 1
    fi
done

if [ "$CHANGED" -eq 1 ]; then
    echo "pre-commit: auto-staged updated SVGs"
fi

# Regenerate regression baselines (uses the same render pipeline)
echo "pre-commit: regenerating regression baselines..."
for ail in "$SCRIPT_DIR"/examples/*.ail; do
    name="$(basename "$ail" .ail)"
    baseline="$SCRIPT_DIR/tests/baseline/$name.svg"
    css="$(stylesheet_for "$name")"
    flags="$(extra_flags_for "$name")"
    # shellcheck disable=SC2086
    if cargo run --quiet -- "$ail" --stylesheet-css "$css" $flags > "$baseline.tmp" 2>/dev/null; then
        if ! diff -q "$baseline" "$baseline.tmp" > /dev/null 2>&1; then
            mv "$baseline.tmp" "$baseline"
            git add "$baseline"
            CHANGED=1
        else
            rm -f "$baseline.tmp"
        fi
    else
        rm -f "$baseline.tmp"
    fi
done

# Run tests
echo "pre-commit: running tests..."
cargo test --quiet 2>/dev/null || {
    echo "pre-commit: tests failed!"
    exit 1
}

echo "pre-commit: all checks passed"
