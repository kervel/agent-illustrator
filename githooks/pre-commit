#!/usr/bin/env bash
# Pre-commit hook: re-render examples and run tests.
# This catches rendering regressions before they get committed.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"

# Only run if source files changed
if ! git diff --cached --name-only | grep -qE '\.(rs|ail|css)$'; then
    exit 0
fi

echo "pre-commit: re-rendering example SVGs..."

# Build first (needed for rendering)
cargo build --quiet 2>/dev/null || {
    echo "pre-commit: cargo build failed, skipping SVG check"
    exit 0
}

# Re-render all examples using the shared render script
CHANGED=0
while IFS= read -r line; do
    if [[ "$line" == OK* ]]; then
        name="${line#OK  }"
        svg="$SCRIPT_DIR/examples/$name"
        if ! git diff --quiet -- "$svg" 2>/dev/null; then
            echo "  CHANGED: $name"
            git add "$svg"
            CHANGED=1
        fi
    elif [[ "$line" == FAIL* ]]; then
        echo "  $line"
        exit 1
    fi
done < <(bash "$SCRIPT_DIR/examples/render-all.sh" 2>/dev/null)

if [ "$CHANGED" -eq 1 ]; then
    echo "pre-commit: auto-staged updated SVGs"
fi

# Regenerate regression baselines
echo "pre-commit: regenerating regression baselines..."
for svg in "$SCRIPT_DIR"/examples/*.svg; do
    name="$(basename "$svg")"
    baseline="$SCRIPT_DIR/tests/baseline/$name"
    if [ -f "$baseline" ]; then
        if ! diff -q "$svg" "$baseline" > /dev/null 2>&1; then
            cp "$svg" "$baseline"
            git add "$baseline"
            CHANGED=1
        fi
    fi
done

# Run tests
echo "pre-commit: running tests..."
cargo test --quiet 2>/dev/null || {
    echo "pre-commit: tests failed!"
    exit 1
}

echo "pre-commit: all checks passed"
