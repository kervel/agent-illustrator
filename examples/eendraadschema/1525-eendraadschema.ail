// ============================================================
// LAYOUT (positional)
// ============================================================

// Bus: horizontal rail at y=240
constrain bus.left = 10
constrain bus.top = 240

// ---- Main feed cluster (ABOVE bus, x=140) ----
constrain main_sw.center_x = 140
constrain main_sw.top = 20
constrain main_sw_lbl.left = main_sw.right + 4
constrain main_sw_lbl.center_y = main_sw.center_y

constrain main_kwh.center_x = 140
constrain main_kwh.top = main_sw.bottom + 18

constrain main_diff_300.center_x = 100
constrain main_diff_300.top = main_kwh.bottom + 18
constrain main_diff_30.center_x = 190
constrain main_diff_30.top = main_kwh.bottom + 18

// drops from diffs down to bus
constrain main_drop1.center_x = main_diff_300.center_x
constrain main_drop1.top = main_diff_300.bottom
constrain main_drop2.center_x = main_diff_30.center_x
constrain main_drop2.top = main_diff_30.bottom

// ---- PV subgroup (below bus, x=50) ----
constrain pv_drop.center_x = 50
constrain pv_drop.top = 244
constrain pv_main.center_x = 50
constrain pv_main.top = 270
constrain pv_kwh.center_x = 50
constrain pv_kwh.top = pv_main.bottom + 14
constrain pv_30.center_x = 50
constrain pv_30.top = pv_kwh.bottom + 14
constrain pv_brk.center_x = 50
constrain pv_brk.top = pv_30.bottom + 14
constrain pv_cable1.center_x = 50
constrain pv_cable1.top = pv_brk.bottom + 6
