// 1525 Kessel-Lo - EL-02 - Eendraadschema
// Source: 1525 Kessel-Lo - EL-02 - versie A.pdf
// Contents only (no legend, no title block)

// ============================================================
// ATOMIC TEMPLATES
// ============================================================

template "brk2p" (spec: "2P C20") {
    rect body [width: 36, height: 22, fill: none, stroke: foreground-1, stroke_width: 1.5, label: spec, font_size: 8]
    rect top_lead [width: 2, height: 8, fill: foreground-1, stroke: none]
    rect bot_lead [width: 2, height: 8, fill: foreground-1, stroke: none]
    constrain top_lead.center_x = body.center_x
    constrain top_lead.bottom = body.top
    constrain bot_lead.center_x = body.center_x
    constrain bot_lead.top = body.bottom
    anchor top_conn [position: top_lead.top, direction: up]
    anchor bot_conn [position: bot_lead.bottom, direction: down]
}

template "brk4p" (spec: "4P C20") {
    rect body [width: 42, height: 22, fill: none, stroke: foreground-1, stroke_width: 1.5, label: spec, font_size: 8]
    rect top_lead [width: 2, height: 8, fill: foreground-1, stroke: none]
    rect bot_lead [width: 2, height: 8, fill: foreground-1, stroke: none]
    constrain top_lead.center_x = body.center_x
    constrain top_lead.bottom = body.top
    constrain bot_lead.center_x = body.center_x
    constrain bot_lead.top = body.bottom
    anchor top_conn [position: top_lead.top, direction: up]
    anchor bot_conn [position: bot_lead.bottom, direction: down]
}

template "diff" (spec: "4P 63A 300mA") {
    rect body [width: 74, height: 26, fill: none, stroke: foreground-1, stroke_width: 1.5, label: spec, font_size: 8]
    rect tbtn [width: 5, height: 5, fill: foreground-1, stroke: none]
    constrain tbtn.right = body.right - 3
    constrain tbtn.top = body.top + 3
    rect top_lead [width: 2, height: 10, fill: foreground-1, stroke: none]
    rect bot_lead [width: 2, height: 10, fill: foreground-1, stroke: none]
    constrain top_lead.center_x = body.center_x
    constrain top_lead.bottom = body.top
    constrain bot_lead.center_x = body.center_x
    constrain bot_lead.top = body.bottom
    anchor top_conn [position: top_lead.top, direction: up]
    anchor bot_conn [position: bot_lead.bottom, direction: down]
}

template "mainsw" (spec: "4P 63A") {
    rect body [width: 54, height: 22, fill: none, stroke: foreground-1, stroke_width: 1.5, label: spec, font_size: 8]
    rect top_lead [width: 2, height: 8, fill: foreground-1, stroke: none]
    rect bot_lead [width: 2, height: 8, fill: foreground-1, stroke: none]
    constrain top_lead.center_x = body.center_x
    constrain top_lead.bottom = body.top
    constrain bot_lead.center_x = body.center_x
    constrain bot_lead.top = body.bottom
    anchor top_conn [position: top_lead.top, direction: up]
    anchor bot_conn [position: bot_lead.bottom, direction: down]
}

template "kwh" (id: "kWh") {
    circle body [size: 34, fill: none, stroke: foreground-1, stroke_width: 1.5, label: id, font_size: 8]
    rect top_lead [width: 2, height: 8, fill: foreground-1, stroke: none]
    rect bot_lead [width: 2, height: 8, fill: foreground-1, stroke: none]
    constrain top_lead.center_x = body.center_x
    constrain top_lead.bottom = body.top
    constrain bot_lead.center_x = body.center_x
    constrain bot_lead.top = body.bottom
    anchor top_conn [position: top_lead.top, direction: up]
    anchor bot_conn [position: bot_lead.bottom, direction: down]
}

// stopcontact (socket) - red
template "leaf" (id: "A1") {
    circle dot [size: 14, fill: background-1, stroke: #c0392b, stroke_width: 1.5, label: id, font_size: 7]
    anchor top_conn [position: dot.top, direction: up]
    anchor bot_conn [position: dot.bottom, direction: down]
}

// lampenpunt (light) - green
template "leaf_lp" (id: "B1") {
    circle dot [size: 14, fill: background-1, stroke: #27ae60, stroke_width: 1.5, label: id, font_size: 7]
    anchor top_conn [position: dot.top, direction: up]
    anchor bot_conn [position: dot.bottom, direction: down]
}

template "pv_panel" {
    rect body [width: 50, height: 28, fill: none, stroke: foreground-1, stroke_width: 1.5, label: "PV", font_size: 10]
    rect top_lead [width: 2, height: 10, fill: foreground-1, stroke: none]
    constrain top_lead.center_x = body.center_x
    constrain top_lead.bottom = body.top
    anchor top_conn [position: top_lead.top, direction: up]
}

template "inverter" {
    rect body [width: 40, height: 28, fill: none, stroke: foreground-1, stroke_width: 1.5, label: "ac/dc", font_size: 8]
    rect top_lead [width: 2, height: 8, fill: foreground-1, stroke: none]
    rect bot_lead [width: 2, height: 8, fill: foreground-1, stroke: none]
    constrain top_lead.center_x = body.center_x
    constrain top_lead.bottom = body.top
    constrain bot_lead.center_x = body.center_x
    constrain bot_lead.top = body.bottom
    anchor top_conn [position: top_lead.top, direction: up]
    anchor bot_conn [position: bot_lead.bottom, direction: down]
}

// ============================================================
// CIRCUIT COLUMN TEMPLATES (breaker + header + cable)
// ============================================================

template "circ2p" (letter: "A", spec: "2P C20", cable: "VOB 2x2.5 + PE") {
    rect hdr [width: 26, height: 14, fill: none, stroke: none, label: letter, font_size: 11]
    rect drop [width: 2, height: 30, fill: foreground-1, stroke: none]
    rect brk [width: 36, height: 22, fill: none, stroke: foreground-1, stroke_width: 1.5, label: spec, font_size: 8]
    rect brk_bot [width: 2, height: 8, fill: foreground-1, stroke: none]
    rect cab [width: 50, height: 10, fill: none, stroke: none, label: cable, font_size: 6]

    constrain drop.center_x = brk.center_x
    constrain drop.bottom = brk.top
    constrain brk_bot.center_x = brk.center_x
    constrain brk_bot.top = brk.bottom
    constrain hdr.center_x = brk.center_x
    constrain hdr.bottom = drop.top - 4
    constrain cab.center_x = brk.center_x
    constrain cab.top = brk_bot.bottom + 2

    anchor bus_conn [position: drop.top - 2, direction: up]
    anchor trunk_top [position: cab.bottom + 4, direction: down]
}

template "circ4p" (letter: "L2", spec: "4P C20", cable: "VOB 4x2.5 + PE") {
    rect hdr [width: 26, height: 14, fill: none, stroke: none, label: letter, font_size: 11]
    rect drop [width: 2, height: 30, fill: foreground-1, stroke: none]
    rect brk [width: 42, height: 22, fill: none, stroke: foreground-1, stroke_width: 1.5, label: spec, font_size: 8]
    rect brk_bot [width: 2, height: 8, fill: foreground-1, stroke: none]
    rect cab [width: 50, height: 10, fill: none, stroke: none, label: cable, font_size: 6]

    constrain drop.center_x = brk.center_x
    constrain drop.bottom = brk.top
    constrain brk_bot.center_x = brk.center_x
    constrain brk_bot.top = brk.bottom
    constrain hdr.center_x = brk.center_x
    constrain hdr.bottom = drop.top - 4
    constrain cab.center_x = brk.center_x
    constrain cab.top = brk_bot.bottom + 2

    anchor bus_conn [position: drop.top - 2, direction: up]
    anchor trunk_top [position: cab.bottom + 4, direction: down]
}

// ============================================================
// DIAGRAM
// ============================================================

group diagram {
    // bus
    rect bus [width: 1920, height: 3, fill: foreground-1, stroke: none]

    // ---- main feed cluster (above bus) ----
    mainsw main_sw [spec: "4P 63A"]
    text "hoofdschakelaar" main_sw_lbl [font_size: 7, fill: foreground-1]
    kwh main_kwh [id: "kWh"]
    diff main_diff_300 [spec: "4P 63A 300mA"]
    diff main_diff_30 [spec: "4P 63A 30mA"]
    rect main_drop1 [width: 2, height: 70, fill: foreground-1, stroke: none]
    rect main_drop2 [width: 2, height: 70, fill: foreground-1, stroke: none]

    // ---- PV subgroup (leftmost circuit column, below bus) ----
    diff pv_main [spec: "4P 32A 300mA"]
    kwh pv_kwh [id: "kWh 001"]
    diff pv_30 [spec: "2P(L1-L2) 63A 30mA"]
    brk4p pv_brk [spec: "4P 25A"]
    text "XVB 4x6 + PE" pv_cable1 [font_size: 6, fill: foreground-1]
    inverter pv_inv
    text "solarkabel 4mm²" pv_cable2 [font_size: 6, fill: foreground-1]
    pv_panel pv_panels
    text "0. VOEDING PV" pv_title [font_size: 8, fill: foreground-1]
    rect pv_drop [width: 2, height: 22, fill: foreground-1, stroke: none]

    // ---- Circuit columns A..AC ----
    circ2p cA [letter: "A", spec: "2P C20", cable: "VOB 2x2.5+PE"]
    circ2p cB [letter: "B", spec: "2P C16", cable: "VOB 2x1.5+PE"]
    circ2p cC [letter: "C", spec: "2P C16", cable: "VOB 2x1.5+PE"]
