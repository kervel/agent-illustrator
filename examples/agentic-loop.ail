/* INTENT
   Animate the agentic loop as a cinematic sequence using keyframes.
   Each phase appears and disappears, giving every step full visual space.

   Usage:
     agent-illustrator examples/agentic-loop.ail --animate
     agent-illustrator examples/agentic-loop.ail --frame "request"
     agent-illustrator examples/agentic-loop.ail --stylesheet-css examples/agentic-loop.css
*/

// === ACTORS: always visible, spread wide ===

rect cli [width: 180, height: 70, fill: accent-light, stroke: accent-dark, stroke_width: 2.5, label: "CLI Agent"]
rect llm [width: 180, height: 70, fill: secondary-light, stroke: secondary-dark, stroke_width: 2.5, label: "LLM API"]
rect tool [width: 180, height: 70, fill: foreground-3, stroke: foreground-1, stroke_width: 2.5, label: "Tool (bash)"]
rect user [width: 180, height: 70, fill: accent-light, stroke: accent-dark, stroke_width: 2.5, label: "User"]

constrain cli.center_x = 120
constrain cli.center_y = 60
constrain llm.center_x = 520
constrain llm.center_y = 60
constrain tool.center_x = 520
constrain tool.center_y = 380
constrain user.center_x = 120
constrain user.center_y = 380

// === MESSAGE ENVELOPES (positioned, hidden by default via keyframes) ===

rect req1_env [width: 200, height: 80, fill: accent-light, stroke: accent-1, stroke_width: 2, opacity: 0.3, label: "system + user msg"]
rect resp1_env [width: 200, height: 80, fill: secondary-light, stroke: secondary-dark, stroke_width: 2, opacity: 0.3, label: "tool_call: bash"]
rect exec_env [width: 200, height: 100, fill: foreground-3, stroke: foreground-1, stroke_width: 2, opacity: 0.2, label: "$ ls -la"]
rect req2_env [width: 200, height: 80, fill: accent-light, stroke: accent-1, stroke_width: 2, opacity: 0.3, label: "history + result"]
rect resp2_env [width: 200, height: 80, fill: secondary-light, stroke: secondary-dark, stroke_width: 2, opacity: 0.3, label: "text response"]

constrain req1_env.center_x = 320
constrain req1_env.center_y = 60
constrain resp1_env.center_x = 320
constrain resp1_env.center_y = 60
constrain exec_env.center_x = 520
constrain exec_env.center_y = 220
constrain req2_env.center_x = 320
constrain req2_env.center_y = 380
constrain resp2_env.center_x = 120
constrain resp2_env.center_y = 220

// === CONNECTIONS (named for keyframe control) ===

cli.right -> llm.left as send_req1 [stroke: accent-1, stroke_width: 3]
llm.left -> cli.right as recv_resp1 [stroke: secondary-dark, stroke_width: 3]
cli.bottom -> tool.top as exec_tool [stroke: foreground-1, stroke_width: 3]
tool.right -> llm.right as send_req2 [stroke: accent-1, stroke_width: 3]
llm.bottom -> user.top as recv_resp2 [stroke: secondary-dark, stroke_width: 3]

// === KEYFRAMES: cinematic sequence ===

keyframe "startup" {
    hide req1_env, resp1_env, exec_env, req2_env, resp2_env
    hide send_req1, recv_resp1, exec_tool, send_req2, recv_resp2
}

keyframe "request" {
    show req1_env, send_req1
}

keyframe "tool_call" {
    hide req1_env, send_req1
    show resp1_env, recv_resp1
}

keyframe "execute" {
    hide resp1_env, recv_resp1
    show exec_env, exec_tool
}

keyframe "return" {
    hide exec_env, exec_tool
    show req2_env, send_req2
}

keyframe "respond" {
    hide req2_env, send_req2
    show resp2_env, recv_resp2
}
