// ============================================================
// TRUE POSITIVES: Layout problems a linter SHOULD catch
// Each section contains a deliberate defect.
// ============================================================


// ------------------------------------------------------------
// TEST 1: Two opaque sibling rectangles overlapping
// Both rects are fully opaque, similar size, positioned so
// they collide. This is almost always a layout bug.
// ------------------------------------------------------------

group overlap_rects {
    rect solid_box_a [width: 120, height: 60, fill: accent-1, stroke: foreground-1, label: "Box A"]
    rect solid_box_b [width: 120, height: 60, fill: accent-2, stroke: foreground-1, label: "Box B"]
}

// Place them so they overlap by ~40px horizontally
constrain solid_box_a.center_x = 100
constrain solid_box_a.center_y = 60
constrain solid_box_b.center_x = 180
constrain solid_box_b.center_y = 60


// ------------------------------------------------------------
// TEST 2: Two text labels overlapping each other
// Labels placed at nearly the same position — unreadable.
// ------------------------------------------------------------

group overlap_labels {
    text "Temperature" label_temp [font_size: 14, fill: foreground-1]
    text "Pressure" label_press [font_size: 14, fill: foreground-1]
}

constrain label_temp.center_x = 400
constrain label_temp.center_y = 60
constrain label_press.center_x = 420
constrain label_press.center_y = 65


// ------------------------------------------------------------
// TEST 3: Connection routing through a solid element
// The connection from src to dst passes through blocker,
// which is fully opaque and is neither source nor target.
// ------------------------------------------------------------

group conn_through_solid {
    rect src [width: 80, height: 40, fill: accent-light, stroke: accent-dark, label: "Source"]
    rect blocker [width: 80, height: 60, fill: accent-1, stroke: foreground-1, label: "Blocker"]
    rect dst [width: 80, height: 40, fill: accent-light, stroke: accent-dark, label: "Dest"]
}

// Place blocker directly between src and dst
constrain src.center_x = 100
constrain src.center_y = 200
constrain blocker.center_x = 100
constrain blocker.center_y = 280
constrain dst.center_x = 100
constrain dst.center_y = 360

// This connection must route through blocker
src -> dst


// ------------------------------------------------------------
// TEST 4: Contains constraint not satisfied
// The container has a hard-constrained right edge that conflicts
// with the contains requirement — the solver can't expand the
// container far enough. The linter should verify the final
// geometry and report the containment violation.
// ------------------------------------------------------------

group broken_contains {
    rect container_box [fill: secondary-light, stroke: secondary-dark, stroke_width: 2, label: "Container"]
    rect escapee [width: 60, height: 40, fill: accent-1, stroke: foreground-1, label: "Escapee"]
    rect extra [width: 60, height: 40, fill: accent-2, stroke: foreground-1, label: "Extra"]
}

// Position elements far apart
constrain escapee.center_x = 350
constrain escapee.center_y = 280
constrain extra.center_x = 550
constrain extra.center_y = 280

// Container should wrap both, but we also pin its right edge too close
constrain container_box contains escapee, extra [padding: 10]
constrain container_box.right = 450


// ------------------------------------------------------------
// TEST 5: Reducible bend — short interior segment in orthogonal path
// A left→top connection where the target's top anchor is just barely
// to the right of the source's left anchor, forcing an extra stub.
// ------------------------------------------------------------

group reducible_bend_test {
    rect source_rb [width: 120, height: 40, fill: accent-1, stroke: foreground-1, label: "Source"]
    rect target_rb [width: 100, height: 40, fill: accent-2, stroke: foreground-1, label: "Target"]
}

constrain source_rb.center_x = 300
constrain source_rb.center_y = 450
constrain target_rb.center_x = 250
constrain target_rb.center_y = 550

source_rb.left -> target_rb.top


// ------------------------------------------------------------
// TEST 6: Label straddling the edge of another element
// An element with a long label placed next to another element
// so the label text extends past its own element and crosses
// the edge of the neighbouring element. This looks like
// accidental placement and should be flagged.
// ------------------------------------------------------------

group label_straddle_test {
    rect straddle_box_a [width: 100, height: 50, fill: accent-1, stroke: foreground-1, label: "This Label Is Very Long"]
    rect straddle_box_b [width: 100, height: 50, fill: accent-2, stroke: foreground-1, label: "Neighbour"]
}

// Place them so box_a's long label text extends into box_b
constrain straddle_box_a.center_x = 500
constrain straddle_box_a.center_y = 460
constrain straddle_box_b.center_x = 610
constrain straddle_box_b.center_y = 460


// ------------------------------------------------------------
// TEST 7: Missing anchors on connections
// Connections without explicit anchors (src -> dst in TEST 3
// already covers this, but let's add a dedicated case)
// The src -> dst connection on line 62 has no anchors.
// ------------------------------------------------------------


// ------------------------------------------------------------
// TEST 8: Dark fill with label — contrast problem
// A rect with a dark fill token and a label. The label text
// will be unreadable against the dark background.
// ------------------------------------------------------------

group contrast_test {
    rect dark_box [width: 120, height: 60, fill: foreground-1, stroke: foreground-1, label: "Unreadable"]
}

constrain dark_box.center_x = 700
constrain dark_box.center_y = 60


// ------------------------------------------------------------
// TEST 9: Steep diagonal direct connection
// A direct-routed connection at ~45° angle looks poor when
// mixed with orthogonal routes.
// ------------------------------------------------------------

group steep_direct_test {
    rect steep_src [width: 80, height: 40, fill: accent-1, stroke: foreground-1, label: "From"]
    rect steep_dst [width: 80, height: 40, fill: accent-2, stroke: foreground-1, label: "To"]
}

constrain steep_src.center_x = 600
constrain steep_src.center_y = 200
constrain steep_dst.center_x = 800
constrain steep_dst.center_y = 300

steep_src.right -> steep_dst.left [routing: direct]


// ------------------------------------------------------------
// TEST 10: Crowded row layout with >8 children
// A row with too many children should suggest using constraints.
// ------------------------------------------------------------

row crowded_row {
    rect cr_1 [width: 30, height: 30, fill: accent-1]
    rect cr_2 [width: 30, height: 30, fill: accent-1]
    rect cr_3 [width: 30, height: 30, fill: accent-1]
    rect cr_4 [width: 30, height: 30, fill: accent-1]
    rect cr_5 [width: 30, height: 30, fill: accent-1]
    rect cr_6 [width: 30, height: 30, fill: accent-1]
    rect cr_7 [width: 30, height: 30, fill: accent-1]
    rect cr_8 [width: 30, height: 30, fill: accent-1]
    rect cr_9 [width: 30, height: 30, fill: accent-1]
}

constrain cr_1.center_y = 650


// ------------------------------------------------------------
// TEST 11: Over-constrained — the right edge pin from TEST 4
// conflicts with the contains constraint. The solver satisfies
// the right = 450 pin, but the containment constraint also implies
// container_box.right >= extra.right + 10 (padding).
// extra is at center_x=550, width auto ~60 → right ~580.
// So the solver cannot satisfy right=450 AND right>=590.
// The over-constrained check sees the constant 450 is honored,
// but we add a new equality that will be violated.
// ------------------------------------------------------------

group over_constrained_test {
    rect oc_a [width: 80, height: 40, fill: accent-1, stroke: foreground-1, label: "A"]
    rect oc_b [width: 80, height: 40, fill: accent-2, stroke: foreground-1, label: "B"]
}

// Pin both elements at known positions
constrain oc_a.center_x = 100
constrain oc_a.center_y = 720
constrain oc_b.center_x = 300
constrain oc_b.center_y = 720

// This equality can't hold: oc_a.left = oc_a.center_x - 40 = 60
// oc_b.right = oc_b.center_x + 40 = 340. 60 != 340.
constrain oc_a.left = oc_b.right
